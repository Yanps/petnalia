{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/atoms/**",
              "components/core/**",
              "components/domain/**",
              "components/feedback/**",
              "components/forms/**",
              "components/molecules/**",
              "components/navigation/**",
              "components/organisms/**",
              "ui_kits/marketplace/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Inter, Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='AddressPreview'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|address|distanceKm|mapSrc|action|onAction|key|ref|className|style|children)$/]",
        "message": "<AddressPreview> doesn't accept that prop. Declared props: label, address, distanceKm, mapSrc, action, onAction."
      },
      {
        "selector": "JSXOpeningElement[name.name='SavedAddress'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|address|distanceKm|key|ref|className|style|children)$/]",
        "message": "<SavedAddress> doesn't accept that prop. Declared props: id, label, address, distanceKm."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|icon|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> variant must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppointmentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:vetName|vetPhoto|petName|type|status|date|time|address|onPrimary|primaryLabel|key|ref|className|style|children)$/]",
        "message": "<AppointmentCard> doesn't accept that prop. Declared props: vetName, vetPhoto, petName, type, status, date, time, address, onPrimary, primaryLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppointmentCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:home|online)$/]",
        "message": "<AppointmentCard> type must be one of 'home' | 'online'."
