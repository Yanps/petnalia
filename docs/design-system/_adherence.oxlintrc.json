      {
        "selector": "JSXOpeningElement[name.name='AppointmentCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:upcoming|confirmed|pending|completed|cancelled)$/]",
        "message": "<AppointmentCard> status must be one of 'upcoming' | 'confirmed' | 'pending' | 'completed' | 'cancelled'."
