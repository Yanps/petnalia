# ── Core ───────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database ───────────────────────────────────────
DATABASE_URL=postgresql://petnalia:petnalia@localhost:5432/petnalia?schema=public
DIRECT_URL=postgresql://petnalia:petnalia@localhost:5432/petnalia?schema=public

# ── Redis / Queues ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Storage (S3 / MinIO) ───────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=petnalia
S3_FORCE_PATH_STYLE=true

# ── Email ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="PetNalia <nao-responda@petnalia.com.br>"

# ── Geo / Maps ─────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# ── Billing ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Feature flags ──────────────────────────────────
FEATURE_MAGIC_LINK=false
FEATURE_GOOGLE_OAUTH=false
FEATURE_WHATSAPP=false
FEATURE_POLYGON_SERVICE_AREA=false
