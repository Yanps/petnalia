{
  "name": "@petnalia/validation",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && echo '{\"type\":\"commonjs\"}' > dist/package.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@petnalia/tsconfig": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
